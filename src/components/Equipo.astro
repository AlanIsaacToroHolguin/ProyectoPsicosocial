---
// Edita estos integrantes con los datos reales del equipo profesional.
const equipo = [
  { nombre: 'Yuliana', foco: 'Facilitación de talleres pedagógicos y aplicación de cartografía social con la comunidad educativa.', img: '/members/MiPsicologa.jpg' },
  { nombre: 'Sara',    foco: 'Espacios de escucha activa con estudiantes, docentes y familias para visibilizar lo no nombrado.',    img: '/members/2.jpeg' },
  { nombre: 'Keidy',   foco: 'Diseño metodológico del proceso y construcción de los instrumentos del diagnóstico.',                 img: '/members/Keidy.jpeg' },
  { nombre: 'Yulissa', foco: 'Lectura psicosocial de hallazgos y elaboración del mapa de riesgos psicosociales.',                   img: '/members/4.jpeg' },
];
---
<section id="equipo" class="relative bg-cream-100 py-20 md:py-28 grain">
  <div class="container-edit">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-20 items-end">
      <div class="lg:col-span-7 reveal-stagger">
        <span class="eyebrow reveal">Quiénes lideran el proyecto</span>
        <h2 class="reveal h-display mt-6 text-[clamp(2rem,4.4vw,3.4rem)] leading-[1.06]">
          Un equipo profesional, <br/>
          un compromiso <em class="not-italic text-terracotta-500">profundamente humano</em>.
        </h2>
      </div>
      <p class="lg:col-span-5 reveal text-lg leading-relaxed text-ink-700">
        Diseñamos e implementamos un <strong class="text-ink-900 font-medium">diagnóstico psicosocial</strong>
        que hace visible la red de factores de riesgo y protección que opera dentro de las comunidades educativas.
      </p>
    </div>

    <div class="reveal-stagger mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {equipo.map((p) => (
        <article class="reveal lift group relative overflow-hidden rounded-3xl bg-cream-50 shadow-soft">
          <div class="relative aspect-[4/5] overflow-hidden">
            <img src={p.img} alt={p.nombre} class="h-full w-full object-cover transition-transform duration-[1200ms] group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/75 via-ink-900/0 to-transparent"></div>
            <div class="absolute bottom-5 left-5 right-5 text-cream-50">
              <div class="font-serif text-xl">{p.nombre}</div>
            </div>
          </div>
          <div class="p-6">
            <p class="text-sm leading-relaxed text-ink-700/90">{p.foco}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Banda informativa: alcance / aplicabilidad / población -->
    <div class="reveal mt-14 grid gap-6 rounded-[2rem] border border-cream-200 bg-cream-50 p-8 md:grid-cols-3 md:p-10">
      <div>
        <div class="text-[10px] uppercase tracking-[0.22em] text-clay-600">Alcance</div>
        <div class="mt-2 font-serif text-lg text-ink-900">Instituciones educativas</div>
        <div class="mt-1 text-sm text-ink-700/80">Públicas, privadas y mixtas, urbanas o rurales.</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-[0.22em] text-clay-600">Aplicabilidad</div>
        <div class="mt-2 font-serif text-lg text-ink-900">Metodología replicable</div>
        <div class="mt-1 text-sm text-ink-700/80">Adaptable al contexto y escala de cada institución.</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-[0.22em] text-clay-600">Población</div>
        <div class="mt-2 text-sm text-ink-700">Estudiantes, docentes, directivos y familias que conforman la comunidad educativa.</div>
      </div>
    </div>
  </div>
</section>
